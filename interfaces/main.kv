ScreenManager: 
    LoginScreen: 
        name: "login" 
    RegisterScreen: 
        name: "register" 
    EstoqueScreen: 
        name: "estoque" 
    HistoricoScreen: 
        name: "historico" 

<LoginScreen>: 
    MDBoxLayout: 
        orientation: "vertical" 
        spacing: 20 
        padding: 40 

        MDLabel: 
            text: "Login" 
            halign: "center" 
            theme_text_color: "Primary"
            font_style: "H4"

        MDTextField: 
            id: usuario 
            hint_text: "Usuário"
            mode: "rectangle"

        MDTextField: 
            id: senha 
            hint_text: "Senha"
            mode: "rectangle"
            password: True 

        MDRectangleFlatButton: 
            text: "Entrar"
            pos_hint: {"center_x": .5} 
            on_release: app.login() 

        MDTextButton: 
            text: "Criar conta"
            pos_hint: {"center_x": .5} 
            on_release: app.root.current = "register" 

<RegisterScreen>: 
    MDBoxLayout: 
        orientation: "vertical" 
        spacing: 20 
        padding: 40 

        MDLabel: 
            text: "Criar Conta" 
            halign: "center" 
            theme_text_color: "Primary"
            font_style: "H4"

        MDTextField: 
            id: usuario 
            hint_text: "Usuário"
            mode: "rectangle"

        MDTextField: 
            id: senha 
            hint_text: "Senha"
            mode: "rectangle"
            password: True 

        MDRectangleFlatButton: 
            text: "Registrar"
            pos_hint: {"center_x": .5} 
            on_release: app.registrar_usuario() 

        MDTextButton: 
            text: "Voltar"
            pos_hint: {"center_x": .5} 
            on_release: app.root.current = "login" 

<EstoqueScreen>: 
    MDBoxLayout: 
        orientation: "vertical" 

        MDTopAppBar: 
            title: "Controle de Estoque"
            left_action_items: [["logout", lambda x: app.logout()]]
            right_action_items: [["history", lambda x: app.abrir_historico()]]

        MDBoxLayout: 
            orientation: "vertical" 
            padding: 10 
            spacing: 10 

            MDTextField: 
                id: campo_nome 
                hint_text: "Nome do produto"
                mode: "rectangle"

            MDTextField: 
                id: campo_quantidade 
                hint_text: "Quantidade"
                input_filter: "int"
                mode: "rectangle"

            MDTextField: 
                id: campo_local 
                hint_text: "Local"
                mode: "rectangle"

            MDRectangleFlatButton: 
                text: "Adicionar Produto"
                pos_hint: {"center_x": .5} 
                on_release: app.adicionar_produto()

            ScrollView: 
                MDBoxLayout: 
                    id: lista_produtos 
                    orientation: "vertical" 
                    spacing: 10 
                    size_hint_y: None 
                    height: self.minimum_height 
                    padding: 10 

<HistoricoScreen>: 
    MDBoxLayout: 
        orientation: "vertical" 

        MDTopAppBar: 
            title: "Histórico de Retiradas"
            left_action_items: [["arrow-left", lambda x: app.voltar_estoque()]]

        ScrollView: 
            MDBoxLayout: 
                id: relatorio_container 
                orientation: "vertical" 
                spacing: 10 
                padding: 20 
                size_hint_y: None 
                height: self.minimum_height
